---
import { Image } from 'astro:assets';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import LocalizedText from '../components/LocalizedText.astro';
import type { DualText } from '../data/siteContent';
import { getLocaleFromPath, withLocale } from '../utils/i18n';
import { getLocalizedField } from '../utils/content';
import { getRepositoryName, normalizeRepositoryUrl } from '../utils/projects';

interface Props {
	title: DualText;
	description: DualText;
	summary: DualText;
	role: DualText;
	status: DualText;
	repositoryUrl?: string;
	stack: DualText[];
	highlights: DualText[];
	mediaTitle?: DualText;
	mediaDescription?: DualText;
	gallery?: {
		image: ImageMetadata;
		alt: DualText;
		caption?: DualText;
	}[];
	heroImage?: ImageMetadata;
}

const { title, description, summary, role, status, repositoryUrl, stack, highlights, mediaTitle, mediaDescription, gallery, heroImage } = Astro.props;
const locale = getLocaleFromPath(Astro.url.pathname);

const resolvedTitle = getLocalizedField(title, locale);
const resolvedDescription = getLocalizedField(description, locale);
const resolvedRepositoryUrl = repositoryUrl ? normalizeRepositoryUrl(repositoryUrl) : undefined;
const resolvedRepositoryLabel = repositoryUrl ? getRepositoryName(repositoryUrl) : undefined;
const isNarrativeCaseStudy =
	Astro.url.pathname.includes('/ue-gas-multiplayer/') ||
	Astro.url.pathname.includes('/unity-factory-td/') ||
	Astro.url.pathname.includes('/unity-metroidvania-action/') ||
	Astro.url.pathname.includes('/unity-campus-career-sim/') ||
	Astro.url.pathname.includes('/ue-steam-networking-plugin/') ||
	Astro.url.pathname.includes('/unity-cockpit-simulation-evaluation/');
// Video wiring is intentionally disabled for now.
// To re-enable it, restore the line below and remove the fallback assignment.
// const narrativeVideoSrc = isNarrativeCaseStudy ? '/media/ue-gas-multiplayer-demo.mp4' : undefined;
const narrativeVideoSrc = undefined;

const labels = {
	back: { zh: '返回项目页', en: 'Back to projects' },
	repository: { zh: '仓库链接', en: 'Repository' },
	summary: { zh: '项目概览', en: 'Overview' },
	role: { zh: '我的职责', en: 'Role' },
	stack: { zh: '技术栈', en: 'Stack' },
	highlights: { zh: '项目亮点', en: 'Highlights' },
	media: { zh: '项目画面', en: 'Project Visuals' },
	heroPlaceholder: { zh: '【游戏实机画面占位】', en: 'Gameplay Footage Placeholder' },
	heroPlaceholderNote: { zh: '这里会放一段视频或循环 GIF。', en: 'A short video or looping GIF will live here.' },
	playDemo: { zh: '播放示意', en: 'Play Demo' },
	// videoUnsupported: { zh: '当前浏览器不支持视频播放。', en: 'Your browser does not support embedded video.' },
};
---

<html lang={locale === 'en' ? 'en' : 'zh-CN'}>
<head>
	<BaseHead title={resolvedTitle} description={resolvedDescription} />
</head>

<body>
<Header />
<main>
	<article class="project-article">
		<div class="project-shell card">
			<a class="back-link" href={withLocale('/projects/', locale)}>
				<LocalizedText locale={locale} text={labels.back} tag="span" />
			</a>

			{
				isNarrativeCaseStudy ? (
					<>
						<section class="case-study-hero card">
							<div class="case-study-hero-media">
								{
									/* Video branch kept here for quick restore:
									narrativeVideoSrc ? (
										<video
											class="case-study-hero-video"
											src={narrativeVideoSrc}
											controls
											muted
											playsinline
											preload="metadata"
										>
											<LocalizedText locale={locale} text={labels.videoUnsupported} tag="span" />
										</video>
									) : */
									heroImage ? (
										<Image width={1400} height={900} src={heroImage} alt="" class="case-study-hero-image" />
									) : (
										<div class="hero-placeholder">
											<div class="hero-placeholder-inner">
												<div class="hero-play-chip">
													<span class="play-icon" aria-hidden="true"></span>
													<LocalizedText locale={locale} text={labels.playDemo} tag="span" class="hero-play-label" />
												</div>
												<LocalizedText locale={locale} text={labels.heroPlaceholder} tag="p" class="hero-placeholder-title" />
												<LocalizedText locale={locale} text={labels.heroPlaceholderNote} tag="p" class="hero-placeholder-note" />
											</div>
										</div>
									)
								}

								<div class="hero-title-wrap">
									<LocalizedText locale={locale} text={status} tag="p" class="hero-kicker" />
									<LocalizedText locale={locale} text={title} tag="h1" class="project-title project-title-overlay" />
								</div>
							</div>

							<div class="case-study-hero-body">
								<LocalizedText locale={locale} text={description} tag="p" class="section-copy project-description narrative-description" />
							</div>
						</section>

						<section class="project-positioning card">
							<div class="pill-row project-positioning-tags">
								{
									stack.map((item) => {
										const zhLabel = item.zh?.trim() ?? '';
										const enLabel = item.en?.trim() ?? '';
										const isSameLabel = zhLabel === enLabel;

										if (locale === 'bi' && !isSameLabel) {
											return (
												<span class="pill stack-pill is-bilingual-pill">
													<span class="pill-label-primary">{zhLabel}</span>
													<span class="pill-label-secondary">{enLabel}</span>
												</span>
											);
										}

										const label = locale === 'en' ? enLabel || zhLabel : zhLabel || enLabel;

										return <span class="pill stack-pill">{label}</span>;
									})
								}
							</div>

							{
								repositoryUrl && (
									<a
										class="project-inline-link"
										href={resolvedRepositoryUrl}
										target="_blank"
										rel="noreferrer"
									>
										<span>{getLocalizedField(labels.repository, locale)}</span>
										<span>{resolvedRepositoryLabel}</span>
									</a>
								)
							}
						</section>

						<section class="project-prose project-prose-narrative">
							<div class="project-summary-intro card">
								<LocalizedText locale={locale} text={summary} tag="p" class="project-summary-copy" />
							</div>
							<slot />
						</section>
					</>
				) : (
					<>
						<section class="project-hero card">
							<div class="project-intro">
								<LocalizedText locale={locale} text={status} tag="p" class="eyebrow project-status" />
								<LocalizedText locale={locale} text={title} tag="h1" class="project-title" />
								<LocalizedText locale={locale} text={description} tag="p" class="section-copy project-description" />
							</div>

							{heroImage && (
								<div class="hero-image">
									<Image width={1200} height={640} src={heroImage} alt="" />
								</div>
							)}

							<div class="project-meta-grid">
								<section class="meta-card overview-card">
									<div class="overview-header">
										<LocalizedText locale={locale} text={labels.summary} tag="h2" class="meta-title" />

										{
											repositoryUrl && (
												<div class="resource-links">
													<span class="resource-label">{getLocalizedField(labels.repository, locale)}</span>
													<div class="resource-entry">
														<a
															class="resource-button"
															href={resolvedRepositoryUrl}
															target="_blank"
															rel="noreferrer"
															aria-label="GitHub Repository"
														>
															<svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
																<path
																	fill="currentColor"
																	d="M12 2C6.48 2 2 6.58 2 12.23c0 4.52 2.87 8.35 6.84 9.7.5.1.68-.22.68-.49 0-.24-.01-1.04-.01-1.89-2.78.62-3.37-1.21-3.37-1.21-.45-1.18-1.11-1.49-1.11-1.49-.91-.64.07-.63.07-.63 1 .07 1.53 1.05 1.53 1.05.9 1.57 2.36 1.12 2.94.86.09-.67.35-1.12.63-1.37-2.22-.26-4.56-1.14-4.56-5.08 0-1.12.39-2.03 1.03-2.75-.1-.26-.45-1.3.1-2.71 0 0 .84-.27 2.75 1.05A9.3 9.3 0 0 1 12 6.84a9.3 9.3 0 0 1 2.5.35c1.9-1.32 2.74-1.05 2.74-1.05.55 1.41.2 2.45.1 2.71.64.72 1.03 1.63 1.03 2.75 0 3.95-2.34 4.81-4.57 5.06.36.32.68.94.68 1.9 0 1.37-.01 2.47-.01 2.81 0 .27.18.59.69.49A10.26 10.26 0 0 0 22 12.23C22 6.58 17.52 2 12 2Z"
																/>
															</svg>
														</a>
														<a
															class="resource-link"
															href={resolvedRepositoryUrl}
															target="_blank"
															rel="noreferrer"
														>
															<span>{resolvedRepositoryLabel}</span>
														</a>
													</div>
												</div>
											)
										}
									</div>

									<LocalizedText locale={locale} text={summary} tag="p" class="meta-copy" />
								</section>

								<section class="meta-card">
									<LocalizedText locale={locale} text={labels.role} tag="h2" class="meta-title" />
									<LocalizedText locale={locale} text={role} tag="p" class="meta-copy" />
								</section>
							</div>

							<section class="meta-card">
								<LocalizedText locale={locale} text={labels.stack} tag="h2" class="meta-title" />
								<div class="pill-row">
									{
										stack.map((item) => {
											const zhLabel = item.zh?.trim() ?? '';
											const enLabel = item.en?.trim() ?? '';
											const isSameLabel = zhLabel === enLabel;

											if (locale === 'bi' && !isSameLabel) {
												return (
													<span class="pill stack-pill is-bilingual-pill">
														<span class="pill-label-primary">{zhLabel}</span>
														<span class="pill-label-secondary">{enLabel}</span>
													</span>
												);
											}

											const label = locale === 'en' ? enLabel || zhLabel : zhLabel || enLabel;

											return <span class="pill stack-pill">{label}</span>;
										})
									}
								</div>

							</section>

							<section class="meta-card">
								<LocalizedText locale={locale} text={labels.highlights} tag="h2" class="meta-title" />
								<ul class="highlight-list">
									{
										highlights.map((item) => (
											<LocalizedText locale={locale} text={item} tag="li" />
										))
									}
								</ul>
							</section>

							{
								(mediaTitle || mediaDescription || (gallery && gallery.length > 0)) && (
									<section class="meta-card media-card">
										<LocalizedText
											locale={locale}
											text={mediaTitle ?? labels.media}
											tag="h2"
											class="meta-title"
										/>

										{
											mediaDescription && (
												<LocalizedText locale={locale} text={mediaDescription} tag="p" class="meta-copy media-copy" />
											)
										}

										{
											gallery && gallery.length > 0 && (
												<div class="gallery-grid">
													{
														gallery.map((item) => (
															<figure class="gallery-item">
																<Image
																	width={900}
																	height={520}
																	src={item.image}
																	alt={getLocalizedField(item.alt, locale)}
																/>
																{
																	item.caption && (
																		<LocalizedText locale={locale} text={item.caption} tag="figcaption" class="gallery-caption" />
																	)
																}
															</figure>
														))
													}
												</div>
											)
										}
									</section>
								)
							}
						</section>

						<section class="project-prose card">
							<slot />
						</section>
					</>
				)
			}
		</div>
	</article>
</main>
<Footer locale={locale} />
</body>
</html>

<style>
	main {
		width: calc(100% - 2em);
		max-width: 100%;
		margin: 0;
	}

	.project-shell {
		width: min(1080px, calc(100% - 2rem));
		margin: 1rem auto 0;
		padding: 1.5rem;
	}

	.back-link {
		display: inline-flex;
		margin-bottom: 1.4rem;
		color: var(--accent-dark);
		font-weight: 700;
		text-decoration: none;
	}

	.project-hero,
	.project-prose {
		padding: 1.5rem;
	}

	.project-hero {
		background:
			linear-gradient(180deg, rgba(255, 255, 255, 0.96) 0%, rgba(246, 250, 255, 0.92) 100%);
	}

	.project-status {
		margin-bottom: 0.65rem;
	}

	.project-title {
		margin: 0;
		font-size: clamp(2rem, 3vw, 2.8rem);
		line-height: 1.06;
	}

	.project-title :global(.locale-en) {
		display: block;
		margin-top: 0.45rem;
		font-size: 0.34em;
		font-weight: 400;
		line-height: 1.35;
		opacity: 0.8;
	}

	.project-description {
		margin-top: 1rem;
		max-width: 820px;
	}

	.case-study-hero {
		padding: 0 0 1.5rem;
		background:
			linear-gradient(180deg, rgba(255, 255, 255, 0.96) 0%, rgba(246, 250, 255, 0.92) 100%);
	}

	.case-study-hero-media {
		position: relative;
		min-height: max(48vh, 360px);
		border-radius: 22px;
		overflow: hidden;
		background:
			linear-gradient(135deg, rgba(232, 240, 251, 0.92) 0%, rgba(245, 249, 255, 0.98) 100%);
		border: 1px solid rgba(158, 177, 201, 0.28);
		box-shadow: 0 18px 38px rgba(31, 61, 109, 0.08);
	}

	.case-study-hero-image {
		display: block;
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.case-study-hero-video {
		display: block;
		width: 100%;
		height: 100%;
		object-fit: cover;
		background: #000;
	}

	.hero-placeholder {
		display: grid;
		place-items: center;
		min-height: max(48vh, 360px);
		padding: 2rem;
	}

	.hero-placeholder-inner {
		display: grid;
		gap: 1rem;
		justify-items: center;
		text-align: center;
		color: rgb(var(--gray-dark));
	}

	.hero-play-chip {
		display: inline-flex;
		align-items: center;
		gap: 0.7rem;
		padding: 0.65rem 1rem;
		border: 1px solid rgba(158, 177, 201, 0.35);
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.82);
	}

	.play-icon {
		width: 0;
		height: 0;
		border-top: 8px solid transparent;
		border-bottom: 8px solid transparent;
		border-left: 14px solid currentColor;
	}

	.hero-play-label {
		font-size: 0.9rem;
		font-weight: 700;
	}

	.hero-placeholder-title {
		margin: 0;
		font-size: clamp(1.9rem, 4vw, 3rem);
		font-weight: 700;
		letter-spacing: -0.03em;
	}

	.hero-placeholder-title :global(.locale-en) {
		display: block;
		margin-top: 0.45rem;
		font-size: 0.34em;
		font-weight: 400;
		line-height: 1.35;
		opacity: 0.82;
	}

	.hero-placeholder-note {
		margin: 0;
		max-width: 30rem;
		font-size: 1rem;
		line-height: 1.6;
		color: rgb(var(--gray));
	}

	.hero-placeholder-note :global(.locale-en) {
		display: block;
		margin-top: 0.35rem;
		font-size: 0.9em;
	}

	.hero-title-wrap {
		position: absolute;
		left: 0;
		right: 0;
		bottom: 0;
		padding: 1.8rem;
		background: linear-gradient(180deg, rgba(31, 61, 109, 0.04) 0%, rgba(31, 61, 109, 0.62) 100%);
	}

	.hero-kicker {
		margin: 0 0 0.75rem;
		color: rgba(255, 255, 255, 0.78);
		font-size: 0.82rem;
		font-weight: 700;
		letter-spacing: 0.12em;
		text-transform: uppercase;
	}

	.hero-kicker :global(.locale-en) {
		display: none;
	}

	.project-title-overlay {
		color: #fff;
		font-size: clamp(2rem, 4.3vw, 3.6rem);
		max-width: 13ch;
	}

	.project-title-overlay :global(.locale-en) {
		color: rgba(255, 255, 255, 0.76);
	}

	.case-study-hero-body {
		padding: 1.2rem 1.5rem 0;
	}

	.narrative-description {
		margin: 0;
		max-width: 760px;
	}

	.project-positioning {
		margin-top: 1rem;
		padding: 1.5rem;
	}

	.project-positioning-tags {
		margin-bottom: 1rem;
	}

	.project-inline-link {
		display: inline-flex;
		gap: 0.65rem;
		margin-top: 1rem;
		color: var(--accent-dark);
		font-size: 0.92rem;
		font-weight: 700;
		text-decoration: none;
	}

	.project-inline-link:hover {
		text-decoration: underline;
	}

	.hero-image {
		margin-top: 1.4rem;
	}

	.hero-image img {
		display: block;
		width: 100%;
		border-radius: 22px;
		box-shadow: 0 18px 38px rgba(35, 68, 110, 0.12);
	}

	.project-meta-grid {
		margin-top: 1.4rem;
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1rem;
	}

	.meta-card {
		margin-top: 1rem;
		padding: 1.1rem 1.15rem;
		border: 1px solid rgba(156, 176, 201, 0.26);
		border-radius: 22px;
		background: rgba(255, 255, 255, 0.84);
	}

	.meta-title {
		margin: 0 0 0.75rem;
		font-size: 0.9rem;
		color: var(--accent-dark);
	}

	.overview-header {
		display: flex;
		align-items: flex-start;
		justify-content: space-between;
		gap: 1rem;
	}

	.overview-card .meta-title {
		margin-bottom: 0;
	}

	.meta-copy {
		margin: 0;
		color: rgb(var(--gray-dark));
		line-height: 1.7;
	}

	.resource-links {
		display: flex;
		flex-direction: column;
		align-items: flex-end;
		gap: 0.35rem;
		flex: 0 0 auto;
	}

	.resource-label {
		color: rgb(var(--gray));
		font-size: 0.78rem;
		font-weight: 700;
		text-align: right;
		white-space: nowrap;
	}

	.resource-entry {
		display: inline-flex;
		align-items: center;
		gap: 0.55rem;
		justify-content: flex-end;
	}

	.resource-button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2rem;
		height: 2rem;
		border: 1px solid rgba(156, 176, 201, 0.35);
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.84);
		color: rgb(var(--gray-dark));
		text-decoration: none;
		flex: 0 0 auto;
	}

	.resource-button:hover {
		color: var(--accent-dark);
		border-color: rgba(110, 140, 182, 0.45);
		background: rgba(248, 251, 255, 0.96);
	}

	.resource-button svg {
		width: 1rem;
		height: 1rem;
	}

	.resource-link {
		display: inline-flex;
		align-items: center;
		color: rgb(var(--gray-dark));
		font-size: 0.88rem;
		font-weight: 600;
		text-decoration: none;
		white-space: nowrap;
	}

	.resource-link:hover {
		color: var(--accent-dark);
		text-decoration: underline;
	}

	.highlight-list {
		margin: 0;
		padding-left: 1.15rem;
		display: grid;
		gap: 0.55rem;
		color: rgb(var(--gray-dark));
	}

	.highlight-list :global(.locale-en) {
		margin-top: 0.18rem;
	}

	.stack-pill {
		align-items: flex-start;
		flex-direction: column;
		gap: 0.1rem;
		line-height: 1.12;
	}

	.stack-pill:not(.is-bilingual-pill) {
		align-items: center;
		justify-content: center;
	}

	.pill-label-primary,
	.pill-label-secondary {
		display: block;
	}

	.pill-label-secondary {
		font-size: 0.82em;
		font-weight: 800;
		color: rgb(var(--gray));
	}

	.media-copy {
		max-width: 760px;
	}

	.gallery-grid {
		margin-top: 1rem;
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1rem;
	}

	.gallery-item {
		margin: 0;
		padding: 0.75rem;
		border-radius: 18px;
		background: rgba(244, 248, 252, 0.92);
	}

	.gallery-item img {
		display: block;
		width: 100%;
		border-radius: 14px;
	}

	.gallery-caption {
		margin-top: 0.65rem;
		color: rgb(var(--gray-dark));
		font-size: 0.92rem;
	}

	.project-prose {
		margin-top: 1rem;
		padding: 1.8rem;
		color: rgb(var(--gray-dark));
		line-height: 1.8;
	}

	.project-prose-narrative {
		margin-top: 1rem;
		padding: 0;
	}

	.project-summary-intro {
		padding: 1.5rem;
		margin-bottom: 1rem;
	}

	.project-summary-copy {
		margin: 0;
		font-size: 1.08rem;
		line-height: 1.85;
		color: rgb(var(--gray-dark));
	}

	.project-summary-copy :global(.locale-en) {
		display: block;
		margin-top: 0.35rem;
		font-size: 0.92em;
		line-height: 1.7;
		color: rgb(var(--gray));
	}

	.project-prose-narrative :global(.role-section),
	.project-prose-narrative :global(.narrative-block),
	.project-prose-narrative :global(.tech-details),
	.project-prose-narrative :global(.outcome-section) {
		padding: 1.5rem;
		margin-bottom: 1rem;
	}

	.project-prose-narrative :global(.section-heading-wrap) {
		margin-bottom: 1.2rem;
