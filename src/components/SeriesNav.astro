---
import LocalizedText from './LocalizedText.astro';
import type { DualText } from '../data/siteContent';

interface SeriesLink {
	href: string;
	label: DualText;
	title: DualText;
}

interface Props {
	previous?: SeriesLink;
	next?: SeriesLink;
	locale?: string;
}

const { previous, next, locale = 'zh' } = Astro.props;
const hasLinks = Boolean(previous || next);
const navLabel = locale === 'en' ? 'Series navigation' : '\u7cfb\u5217\u5bfc\u822a';
---

{hasLinks && (
	<nav class="series-nav" aria-label={navLabel}>
		{previous && (
			<a class="series-nav-card" href={previous.href}>
				<LocalizedText locale={locale} text={previous.label} tag="span" />
				<LocalizedText locale={locale} text={previous.title} tag="strong" />
			</a>
		)}
		{next && (
			<a class="series-nav-card is-next" href={next.href}>
				<LocalizedText locale={locale} text={next.label} tag="span" />
				<LocalizedText locale={locale} text={next.title} tag="strong" />
			</a>
		)}
	</nav>
)}
