---
import Footer from './Footer.astro';
import Header from './Header.astro';
import LocalizedText from './LocalizedText.astro';
import { resumeContent, type DualText } from '../data/siteContent';
import { getContentPath, type Locale } from '../utils/i18n';

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const coreProjects = resumeContent.projects.slice(0, 4);
const additionalProjects = resumeContent.projects.slice(4);

const skillGroups: { title: DualText; items: DualText[] }[] = [
	{
		title: { zh: '引擎', en: 'Engines' },
		items: resumeContent.skills.slice(0, 2),
	},
	{
		title: { zh: '联机', en: 'Networking' },
		items: [resumeContent.skills[6], resumeContent.skills[7], resumeContent.skills[12]],
	},
	{
		title: { zh: '系统', en: 'Systems' },
		items: [
			resumeContent.skills[2],
			resumeContent.skills[3],
			resumeContent.skills[4],
			resumeContent.skills[5],
			resumeContent.skills[8],
			resumeContent.skills[9],
			resumeContent.skills[10],
			resumeContent.skills[11],
		],
	},
	{
		title: { zh: '工程', en: 'Workflow' },
		items: [resumeContent.skills[13], resumeContent.skills[14], resumeContent.skills[15], resumeContent.skills[16]],
	},
];

const caseStudyLinkText =
	locale === 'zh'
		? '查看项目详情'
		: locale === 'en'
			? 'View case study'
			: '查看项目详情 / View case study';
---

<Header />

<main>
	<div class="resume-board" id="resume-board" data-layout="single">
		<section class="page-hero">
			<div class="card identity-card">
				<LocalizedText locale={locale} text={resumeContent.title} tag="p" class="eyebrow resume-eyebrow" />
				<LocalizedText locale={locale} text={resumeContent.identity.name} tag="p" class="resume-name" />
				<LocalizedText locale={locale} text={resumeContent.identity.role} tag="p" class="resume-role" />
				<LocalizedText locale={locale} text={resumeContent.description} tag="p" class="section-copy hero-description" />
			</div>
		</section>

		<section class="resume-layout">
			<aside class="resume-sidebar">
				<article class="card section-card meta-card" data-scroll-anchor="skills">
					<LocalizedText locale={locale} text={resumeContent.skillsTitle} tag="h2" class="section-title" />
					<div class="skill-groups">
						{
							skillGroups.map((group) => (
								<section class="skill-group">
									<LocalizedText locale={locale} text={group.title} tag="h3" class="skill-group-title" />
									<div class="skills-cloud">
										{
											group.items.map((skill) => (
												<span class="skill-pill">
													<LocalizedText locale={locale} text={skill} tag="span" />
												</span>
											))
										}
									</div>
								</section>
							))
						}
					</div>
				</article>

				<article class="card section-card meta-card" data-scroll-anchor="education">
					<LocalizedText locale={locale} text={resumeContent.educationTitle} tag="h2" class="section-title" />
					<div class="detail-block">
						<LocalizedText locale={locale} text={resumeContent.education.school} tag="h3" class="detail-title" />
						<LocalizedText locale={locale} text={resumeContent.education.degree} tag="p" class="detail-subtitle" />
						<ul class="detail-list">
							{
								resumeContent.education.details.map((detail) => (
									<LocalizedText locale={locale} text={detail} tag="li" />
								))
							}
						</ul>
					</div>
				</article>

				<article class="card section-card meta-card" data-scroll-anchor="society">
					<LocalizedText locale={locale} text={resumeContent.societyTitle} tag="h2" class="section-title" />
					<div class="detail-block">
						<LocalizedText locale={locale} text={resumeContent.society.organization} tag="h3" class="detail-title" />
						<LocalizedText locale={locale} text={resumeContent.society.role} tag="p" class="detail-subtitle" />
						<ul class="detail-list">
							{
								resumeContent.society.details.map((detail) => (
									<LocalizedText locale={locale} text={detail} tag="li" />
								))
							}
						</ul>
					</div>
				</article>

				<article class="card section-card compact-projects-card" data-column-tail="sidebar" data-scroll-anchor="additional-projects">
					<LocalizedText locale={locale} text={resumeContent.additionalProjectsTitle} tag="h2" class="section-title subsection-title" />
					<div class="project-list project-list-compact">
						{
							additionalProjects.map((project, index) => (
								<section class="project-block project-block-compact" data-scroll-anchor={`extra-${index}`}>
									{
										project.slug ? (
											<a class="project-title-link" href={getContentPath('projects', project.slug, locale)}>
												<LocalizedText locale={locale} text={project.title} tag="h3" class="project-title project-title-compact" />
											</a>
										) : (
											<LocalizedText locale={locale} text={project.title} tag="h3" class="project-title project-title-compact" />
										)
									}
									{
										project.stack ? (
											<div class="project-stack-cloud project-stack-cloud-compact" aria-label="Project tech stack">
												{
													project.stack.map((tag) => (
														<span class="project-stack-pill project-stack-pill-compact">
															<LocalizedText locale={locale} text={tag} tag="span" />
														</span>
													))
												}
											</div>
										) : null
									}
									<ul class="project-points project-points-compact">
										{
											project.bullets.slice(0, 1).map((bullet) => (
												<LocalizedText locale={locale} text={bullet} tag="li" />
											))
										}
									</ul>
								</section>
							))
						}
					</div>
				</article>
			</aside>

			<section class="resume-main">
				<article class="card section-card summary-card" data-scroll-anchor="summary">
					<LocalizedText locale={locale} text={resumeContent.summaryTitle} tag="h2" class="section-title" />
					<LocalizedText locale={locale} text={resumeContent.summary} tag="p" class="summary-copy" />
				</article>

				<article class="card section-card projects-card" data-column-tail="main">
					<LocalizedText locale={locale} text={resumeContent.projectsTitle} tag="h2" class="section-title" />

					<div class="project-list">
						{
							coreProjects.map((project, index) => (
								<section class="project-block" data-scroll-anchor={`project-${index}`}>
									{
										project.slug ? (
											<div class="project-heading">
												<a class="project-title-link" href={getContentPath('projects', project.slug, locale)}>
													<LocalizedText locale={locale} text={project.title} tag="h3" class="project-title" />
												</a>
												<a class="project-case-link" href={getContentPath('projects', project.slug, locale)}>
													{caseStudyLinkText}
												</a>
											</div>
										) : (
											<LocalizedText locale={locale} text={project.title} tag="h3" class="project-title" />
										)
									}
									{
										project.stack ? (
											<div class="project-stack-cloud" aria-label="Project tech stack">
												{
													project.stack.map((tag) => (
														<span class="project-stack-pill">
															<LocalizedText locale={locale} text={tag} tag="span" />
														</span>
													))
												}
											</div>
										) : null
									}
									<ul class="project-points">
										{
											project.bullets.map((bullet) => (
												<LocalizedText locale={locale} text={bullet} tag="li" />
											))
										}
									</ul>
								</section>
							))
						}
					</div>
				</article>
			</section>
		</section>
	</div>

</main>

<Footer />

<style>
	.page-hero {
		margin-top: 0;
	}

	.resume-board {
		margin-top: 1rem;
		padding: 1.6rem;
		border: 1px solid rgba(156, 176, 201, 0.3);
		border-radius: 30px;
		background:
			linear-gradient(180deg, rgba(231, 239, 248, 0.66) 0%, rgba(239, 245, 252, 0.76) 100%);
		box-shadow:
			0 12px 28px rgba(35, 68, 110, 0.08),
			inset 0 1px 0 rgba(255, 255, 255, 0.68);
	}

	.identity-card {
		padding: 1.7rem 1.8rem;
		display: flex;
		flex-direction: column;
		background:
			linear-gradient(180deg, rgba(255, 255, 255, 0.96) 0%, rgba(245, 250, 255, 0.92) 100%);
	}

	.resume-eyebrow {
		margin-bottom: 0.7rem;
	}

	.resume-name {
		margin: 0;
		font-size: clamp(2rem, 3vw, 2.5rem);
		font-weight: 800;
		line-height: 1.04;
		color: rgb(var(--black));
	}

	.resume-role {
		margin: 0.8rem 0 0;
		font-size: 0.98rem;
		font-weight: 700;
		line-height: 1.42;
		color: var(--accent-dark);
	}

	.hero-description {
		margin-top: 1rem;
		max-width: 780px;
	}

	.resume-layout {
		margin-top: 1.25rem;
		display: grid;
		gap: 1.25rem;
		grid-template-columns: 1fr;
	}

	.resume-sidebar,
	.resume-main {
		display: contents;
	}

	[data-scroll-anchor='summary'] {
		order: 1;
	}

	[data-scroll-anchor='education'] {
		order: 2;
	}

	[data-scroll-anchor='skills'] {
		order: 3;
	}

	[data-scroll-anchor='society'] {
		order: 4;
	}

	.projects-card {
		order: 5;
	}

	[data-scroll-anchor='additional-projects'] {
		order: 6;
	}

	.section-card {
		padding: 1.45rem 1.55rem;
		background:
			linear-gradient(180deg, rgba(255, 255, 255, 0.96) 0%, rgba(248, 251, 255, 0.94) 100%);
	}

	.section-title {
		margin-bottom: 1rem;
		font-size: 0.92rem;
		line-height: 1.18;
	}

	.section-card :global(.locale-en),
	.resume-role :global(.locale-en) {
		color: rgb(var(--gray));
		opacity: 0.78;
	}

	.section-title :global(.locale-en) {
		font-size: 0.78em;
		font-weight: 700;
		letter-spacing: 0.04em;
		opacity: 0.62;
	}

	.skill-groups {
		display: grid;
		gap: 0.95rem;
	}

	.skill-group {
		display: grid;
		gap: 0.45rem;
	}

	.skill-group-title {
		margin: 0;
		font-size: 0.88rem;
		line-height: 1.2;
		color: var(--accent-dark);
	}

	.skill-group-title :global(.locale-en) {
		font-size: 0.86em;
		opacity: 0.72;
	}

	.skills-cloud {
		display: flex;
		flex-wrap: wrap;
		gap: 0.6rem;
	}

	.skill-pill {
		display: inline-flex;
		align-items: center;
		padding: 0.48rem 0.76rem;
		border-radius: 999px;
		background: var(--accent-soft);
		color: var(--accent-dark);
		font-size: 0.88rem;
		font-weight: 700;
		line-height: 1.15;
	}

	.skill-pill :global(.is-bilingual) {
		display: inline-flex;
		flex-direction: column;
		gap: 0.08rem;
	}

	.skill-pill :global(.is-bilingual .locale-en) {
		margin-top: 0;
		font-size: 0.84em;
	}

	.summary-copy {
		margin: 0;
		color: rgb(var(--gray-dark));
		line-height: 1.72;
	}

	.summary-copy :global(.locale-en) {
		font-size: 0.88em;
		line-height: 1.5;
	}

	.detail-title {
		margin-bottom: 0.2rem;
		font-size: 0.95rem;
	}

	.detail-subtitle {
		margin: 0;
		color: rgb(var(--gray));
		font-size: 0.92rem;
	}

	.detail-list {
		margin: 0.6rem 0 0;
		padding-left: 1.1rem;
		display: grid;
		gap: 0.35rem;
	}

	.detail-list li {
		margin: 0;
		color: rgb(var(--gray-dark));
		font-size: 0.93rem;
		line-height: 1.45;
	}

	.detail-list :global(.is-bilingual .locale-en),
	.project-points :global(.is-bilingual .locale-en),
	.resume-role :global(.is-bilingual .locale-en) {
		margin-top: 0.18rem;
	}

	.project-list {
		display: grid;
		gap: 1.35rem;
	}

	.project-block + .project-block {
		padding-top: 1.3rem;
		border-top: 1px solid rgba(158, 177, 201, 0.22);
	}

	.project-title {
		margin-bottom: 0.2rem;
		font-size: 1.08rem;
		line-height: 1.35;
	}

	.project-heading {
		display: grid;
		gap: 0.35rem;
	}

	.project-title-link {
		color: inherit;
		text-decoration: none;
	}

	.project-title-link:hover {
		color: var(--accent-dark);
	}

	.project-case-link {
		width: fit-content;
		color: var(--accent-dark);
		font-size: 0.88rem;
		font-weight: 700;
		text-decoration: none;
	}

	.project-case-link:hover {
		text-decoration: underline;
	}

	.project-stack-cloud {
		margin-top: 0.65rem;
		display: flex;
		flex-wrap: wrap;
		gap: 0.45rem;
	}

	.project-stack-pill {
		display: inline-flex;
		align-items: center;
		padding: 0.34rem 0.62rem;
		border: 1px solid rgba(72, 118, 162, 0.18);
		border-radius: 999px;
		background: rgba(232, 242, 252, 0.74);
		color: var(--accent-dark);
		font-size: 0.8rem;
		font-weight: 700;
		line-height: 1.15;
	}

	.project-stack-cloud-compact {
		margin-top: 0.5rem;
		gap: 0.36rem;
	}

	.project-stack-pill-compact {
		padding: 0.28rem 0.52rem;
		font-size: 0.72rem;
	}

	.project-points {
		margin: 0.85rem 0 0;
		padding-left: 1.2rem;
		display: grid;
		gap: 0.55rem;
	}

	.project-points li {
		margin: 0;
		color: rgb(var(--gray-dark));
	}

	.subsection-title {
		color: var(--accent-dark);
	}

	.project-list-compact {
		gap: 0.9rem;
	}

	.project-block-compact + .project-block-compact {
		padding-top: 0.95rem;
	}

	.project-title-compact {
		font-size: 0.98rem;
		line-height: 1.28;
	}

	.project-points-compact {
		margin-top: 0.6rem;
		gap: 0.35rem;
	}

	.project-points-compact li {
		font-size: 0.92rem;
		line-height: 1.5;
	}

	@media (max-width: 720px) {
		.resume-board {
			padding: 1rem;
			border-radius: 24px;
		}
	}
</style>
