---
import type { CollectionEntry } from 'astro:content';
import Footer from './Footer.astro';
import Header from './Header.astro';
import FormattedDate from './FormattedDate.astro';
import LocalizedText from './LocalizedText.astro';
import { homeContent } from '../data/siteContent';
import { getContentPath, withLocale, type Locale } from '../utils/i18n';

interface Props {
    locale: Locale;
    posts: CollectionEntry<'blog'>[];
}

const { locale, posts } = Astro.props;

const featuredProjectLinkText = {
    zh: '查看详情',
    en: 'View Case Study',
};
---

<Header />

<main>
    <section class="hero card">
        <div class="hero-heading-block">
            {
                locale === 'bi' ? (
                        <>
                            <h1 class="hero-title">{homeContent.title.zh}</h1>
                            <p class="hero-title-en">{homeContent.title.en}</p>
                        </>
                ) : (
                        <LocalizedText locale={locale} text={homeContent.title} tag="h1" class="hero-title" />
                )
            }
        </div>

        <div class="hero-body">
            <div class="hero-copy">
                <LocalizedText locale={locale} text={homeContent.description} tag="p" class="hero-text" />

                <div class="hero-actions">
                    <a class="button" href={withLocale('/projects', locale)}>
                        <LocalizedText locale={locale} text={homeContent.buttons.projects} tag="span" class="button-label" />
                    </a>
                    <a class="button secondary" href={withLocale('/blog', locale)}>
                        <LocalizedText locale={locale} text={homeContent.buttons.blog} tag="span" class="button-label" />
                    </a>
                </div>
            </div>
        </div>
    </section>

    <section class="section-block">
        <div class="section-top">
            <LocalizedText locale={locale} text={homeContent.featuredTitle} tag="h2" class="section-heading" />
            <a href={withLocale('/projects', locale)}>
                {locale === 'bi'
                    ? `${homeContent.featuredLink.zh} / ${homeContent.featuredLink.en}`
                    : locale === 'zh'
                        ? homeContent.featuredLink.zh
                        : homeContent.featuredLink.en}
            </a>
        </div>

        <div class="project-grid card featured-project-list">
            {
                homeContent.projects.map((project) => {
                    const href = project.slug ? getContentPath('projects', project.slug, locale) : null;

                    const content = (
                        <>
                            <div class="featured-project-head">
                                <LocalizedText locale={locale} text={project.name} tag="h3" class="featured-project-title" />
                            </div>

                            <div class="featured-project-body">
                                <LocalizedText locale={locale} text={project.description} tag="p" class="featured-project-copy" />
                            </div>

                            <div class="featured-project-foot">
                                <div class="pill-row project-stack">
                                    {project.stack.map((item) => <span class="pill">{item}</span>)}
                                </div>

                                {
                                    href && (
                                        <span class="featured-project-link">
                                            {locale === 'bi'
                                                ? `${featuredProjectLinkText.zh} / ${featuredProjectLinkText.en}`
                                                : locale === 'zh'
                                                    ? featuredProjectLinkText.zh
                                                    : featuredProjectLinkText.en}
                                        </span>
                                    )
                                }
                            </div>
                        </>
                    );

                    return href ? (
                        <a class="project-card card project-card-link" href={href}>
                            {content}
                        </a>
                    ) : (
                        <article class="project-card card">
                            {content}
                        </article>
                    );
                })
            }
        </div>
    </section>

    <section class="section-block">
        <div class="section-top">
            <LocalizedText locale={locale} text={homeContent.postsTitle} tag="h2" class="section-heading" />
            <a href={withLocale('/blog', locale)}>
                {locale === 'bi'
                    ? `${homeContent.postsLink.zh} / ${homeContent.postsLink.en}`
                    : locale === 'zh'
                        ? homeContent.postsLink.zh
                        : homeContent.postsLink.en}
            </a>
        </div>

        {
            posts.length > 0 ? (
                <div class="post-grid card">
                    {
                        posts.map((post) => (
                                <a class="post-card card" href={withLocale(`/blog/${post.id}/`, locale)}>
                                    <p class="post-date">
                                        <FormattedDate date={post.data.pubDate} />
                                    </p>
                                    <h3>{post.data.title}</h3>
                                    <p>{post.data.description}</p>
                                </a>
                        ))
                    }
                </div>
            ) : (
                <div class="post-grid card post-empty-card">
                    <p>{locale === 'en' ? 'No posts yet.' : locale === 'zh' ? '暂时还没有文章。' : '暂时还没有文章。 / No posts yet.'}</p>
                </div>
            )
        }
    </section>
</main>

<Footer />

<style>
    .hero {
        padding: 2rem;
        display: grid;
        gap: 2rem;
        justify-items: center;
        text-align: center;
    }


    .hero-heading {
        display: flex;
        flex-direction: column;
        gap: 0.9rem;
    }

    .hero-heading-block {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.5rem;
        width: min(100%, 60rem);
        margin-bottom: 0.5rem;
    }

    .hero-title {
        max-width: none;
        margin: 0;
        font-size: clamp(2.55rem, 5vw, 4rem);
        line-height: 1.08;
        letter-spacing: -0.04em;
    }

    .hero-title-en {
        margin: 0;
        font-size: clamp(1.2rem, 2.2vw, 1.95rem);
        font-weight: 700;
        line-height: 1.2;
        color: rgb(var(--gray-dark));
    }

    .hero-body {
        width: min(100%, 42rem);
        display: grid;
        gap: 0;
        justify-items: center;
    }

    .hero-copy {
        display: flex;
        flex-direction: column;
        align-items: center;
        max-width: none;
    }

    .hero-text {
        max-width: 32rem;
        margin: 0;
        font-size: 1rem;
        color: rgb(var(--gray));
        line-height: 1.8;
    }


    .hero-actions {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 0.9rem;
        margin-top: 1.7rem;
    }

    .button-label {
        line-height: 1.2;
    }

    .section-block {
        margin-top: 4.25rem;
    }

    .section-top {
        display: flex;
        align-items: end;
        justify-content: space-between;
        gap: 1rem;
        margin-bottom: 1.25rem;
    }

    .project-grid,
    .post-grid {
        display: grid;
        gap: 2rem;
        padding: 1.35rem;
        grid-template-columns: repeat(1,3fr);
        align-items: stretch;
    }

    .featured-project-list {
        grid-template-columns: repeat(1,3fr);
    }

    .project-card,
    .post-card {
        padding: 1.35rem;
    }

    .project-card {
        display: grid;
        grid-template-columns: 1fr;
        grid-template-rows: minmax(1rem, auto) minmax(1rem, auto) 1fr;
        gap: 0;
        min-height: 0;
    }

    .project-card-link {
        color: inherit;
        text-decoration: none;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .project-card-link:hover {
        transform: translateY(-2px);
    }

    .project-card p,
    .post-card p {
        margin-bottom: 0;
        color: rgb(var(--gray));
    }

    :global(.featured-project-title) {
        margin: 0;
        font-size: clamp(1.28rem, 1.5vw, 1.55rem);
        line-height: 1.18;
        letter-spacing: -0.025em;
    }

    :global(.featured-project-title .locale-en) {
        font-size: 0.82em;
        line-height: 1.18;
    }

    .featured-project-copy,
    .project-card :global(p.is-bilingual),
    .project-card p {
        line-height: 1.62;
    }

    .featured-project-head,
    .featured-project-body,
    .featured-project-foot {
        display: flex;
        flex-direction: column;
    }

    .featured-project-head {
        padding-bottom: 0.9rem;
        overflow: hidden;
    }

    .featured-project-body {
        padding-top: 0;
        padding-bottom: 1rem;
        overflow: hidden;
    }

    .featured-project-foot {
        justify-content: flex-start;
        align-self: stretch;
        min-width: 0;
    }

    .project-stack {
        margin-top: 0;
        padding-top: 0;
        justify-content: flex-start;
    }

    .featured-project-link {
        display: inline-flex;
        margin-top: 1rem;
        color: var(--accent-dark);
        font-size: 0.88rem;
        font-weight: 700;
        justify-content: flex-start;
    }

    .post-card {
        text-decoration: none;
        color: inherit;
    }

    .post-empty-card {
        color: rgb(var(--gray));
    }

    .post-empty-card p {
        margin: 0;
    }

    .post-card:hover {
        transform: translateY(-2px);
        transition: 0.2s ease;
    }

    .post-date {
        margin-bottom: 0.7rem;
        font-size: 0.9rem;
        font-weight: 700;
        color: var(--accent);
    }

    @media (max-width: 900px) {
        .project-card {
            grid-template-rows: auto auto auto;
        }
    }

    @media (max-width: 900px) {
        .project-grid,
        .post-grid {
            grid-template-columns: 1fr;
        }
    }
</style>
