---
import { Image } from 'astro:assets';
import Footer from './Footer.astro';
import Header from './Header.astro';
import LocalizedText from './LocalizedText.astro';
import AvatarImage from '../assets/头像.jpg';
import { aboutContent } from '../data/siteContent';
import type { Locale } from '../utils/i18n';

interface Props {
    locale: Locale;
}

const { locale } = Astro.props;
---

<Header />

<main>
    <section class="page-hero">
        <LocalizedText locale={locale} text={aboutContent.title} tag="h1" />
        <LocalizedText locale={locale} text={aboutContent.description} tag="p" class="section-copy" />
    </section>

    <section class="about-grid">
        <article class="card about-card intro-card">
            <div class="intro-head">
                <LocalizedText locale={locale} text={aboutContent.intro.title} tag="h2" />
                <Image width={160} height={160} src={AvatarImage} alt="柒年Lovski avatar" class="avatar-image" />
            </div>
            {
                aboutContent.intro.text.map((paragraph) => (
                    <LocalizedText locale={locale} text={paragraph} tag="p" />
                ))
            }
        </article>

        <article class="card about-card">
            <LocalizedText locale={locale} text={aboutContent.focus.title} tag="h2" />
            <ul>
                {
                    aboutContent.focus.items.map((item) => (
                            <li>{locale === 'bi' ? `${item.zh}\n${item.en}` : locale === 'zh' ? item.zh : item.en}</li>
                    ))
                }
            </ul>
        </article>

        <article class="card about-card">
            <LocalizedText locale={locale} text={aboutContent.why.title} tag="h2" />
            <LocalizedText locale={locale} text={aboutContent.why.text} tag="p" />
        </article>
    </section>
</main>

<Footer />

<style>
    .page-hero {
        margin-top: 1rem;
    }
    .about-grid {
        margin-top: 2rem;
        display: grid;
        grid-template-columns: 1.15fr 0.85fr;
        gap: 1.2rem;
    }
    .about-card {
        padding: 1.5rem;
    }
    .intro-card {
        grid-row: span 2;
    }
    .intro-head {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        align-items: center;
        gap: 1rem;
        margin-bottom: 1rem;
    }
    .intro-head h2 {
        margin: 0;
        min-width: 0;
    }
    .avatar-image {
        width: 92px;
        height: 92px;
        border-radius: 50%;
        object-fit: cover;
        border: 3px solid rgba(255, 255, 255, 0.9);
        box-shadow: 0 14px 28px rgba(20, 43, 74, 0.16);
        flex: 0 0 auto;
    }
    .about-card p,
    .about-card li {
        color: rgb(var(--gray));
    }
    .about-card ul {
        margin: 0;
        padding-left: 1.2rem;
        white-space: pre-line;
    }
    @media (max-width: 820px) {
        .about-grid {
            grid-template-columns: 1fr;
        }
        .intro-card {
            grid-row: auto;
        }
        .avatar-image {
            width: 84px;
            height: 84px;
        }
    }
</style>
