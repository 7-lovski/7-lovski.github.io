---
import LocalizedText from './LocalizedText.astro';
import { footerContent } from '../data/siteContent';
import { getLocaleFromPath } from '../utils/i18n';

const year = new Date().getFullYear();
const locale = getLocaleFromPath(Astro.url.pathname);
---

<footer class="site-footer">
	<div class="footer-shell">
		<div>
			<p class="footer-title">7-lovski</p>
			<LocalizedText locale={locale} text={footerContent.copy} tag="p" class="footer-copy" />
		</div>

		<div class="footer-links">
			<a href="https://github.com/7-lovski" target="_blank" rel="noreferrer">GitHub</a>
			<a href="/blog">Blog</a>
			<a href="/resume">Resume</a>
		</div>
	</div>

	<p class="footer-meta">© {year} 7-lovski. Built with Astro.</p>
</footer>

<style>
	.site-footer {
		margin-top: 5rem;
		padding: 2rem 1.25rem 3rem;
		color: rgb(var(--gray));
	}

	.footer-shell {
		max-width: 1120px;
		margin: 0 auto;
		padding: 1.5rem 1.6rem;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1.25rem;
		border: 1px solid rgba(164, 182, 204, 0.28);
		border-radius: 24px;
		background: rgba(255, 255, 255, 0.9);
		box-shadow: 0 14px 32px rgba(20, 43, 74, 0.05);
	}

	.footer-title {
		margin: 0;
		font-size: 1rem;
		font-weight: 800;
		color: rgb(var(--black));
	}

	:global(.footer-copy) {
		margin: 0.4rem 0 0;
		font-size: 0.95rem;
	}

	.footer-links {
		display: flex;
		flex-wrap: wrap;
		gap: 1rem;
	}

	.footer-links a {
		color: rgb(var(--gray-dark));
		font-weight: 600;
		text-decoration: none;
	}

	.footer-links a:hover {
		color: var(--accent);
	}

	.footer-meta {
		max-width: 1120px;
		margin: 1rem auto 0;
		padding-left: 0.25rem;
		font-size: 0.9rem;
	}

	@media (max-width: 720px) {
		.footer-shell {
			flex-direction: column;
			align-items: flex-start;
		}
	}
</style>
