---
import type { HTMLTag } from 'astro/types';
import type { DualText } from '../data/siteContent';
import { getLocaleFromPath, type Locale } from '../utils/i18n';

interface Props {
    locale: Locale;
    text: DualText;
    tag?: HTMLTag;
    class?: string;
}

const { locale, text, tag = 'p', class: className } = Astro.props;
const Tag = tag;
const zhText = text?.zh ?? '';
const enText = text?.en ?? '';
const isSameText = zhText.trim() === enText.trim();
const routeLocale = getLocaleFromPath(Astro.url.pathname);
const effectiveLocale = locale === 'bi' && routeLocale !== 'bi' ? routeLocale : locale;
---

{
    effectiveLocale === 'bi' && !isSameText ? (
    <Tag class:list={[className, 'is-bilingual']}>
        <span class="locale-zh">{zhText}</span>
        <span class="locale-en">{enText}</span>
    </Tag>
        ) : (
    <Tag class={className}>{effectiveLocale === 'en' ? enText || zhText : zhText || enText}</Tag>
        )
    }

<style>
    .is-bilingual .locale-zh,
    .is-bilingual .locale-en {
        display: block;
    }

    .is-bilingual .locale-en {
        margin-top: 0.22rem;
        font-size: 0.84em;
        opacity: 0.82;
    }
</style>
