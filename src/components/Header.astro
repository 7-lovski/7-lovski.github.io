---
import {SITE_TITLE} from '../consts';
import HeaderLink from './HeaderLink.astro';
import {navigationContent} from '../data/siteContent';
import {
    getLocaleFromPath,
    getLocaleLabel,
    withLocale,
    type Locale,
} from '../utils/i18n';

const pathname = Astro.url.pathname;
const locale = getLocaleFromPath(pathname);

const tagline =
    locale === 'bi'
        ? `${navigationContent.tagline.zh} / ${navigationContent.tagline.en}`
        : locale === 'zh'
            ? navigationContent.tagline.zh
            : navigationContent.tagline.en;

const localeLabel = getLocaleLabel(locale);

const switcherItems: { locale: Locale; label: string }[] = [
    {locale: 'bi', label: '语言 Language：中英双语 Bilingual'},
    {locale: 'zh', label: '语言：中文'},
    {locale: 'en', label: 'Language: English'},
];

function getNavText(text: { zh: string; en: string }) {
    if (locale === 'zh') return {primary: text.zh, secondary: null};
    if (locale === 'en') return {primary: text.en, secondary: null};
    return {primary: text.zh, secondary: text.en};
}
---

<header class="site-header">
    <div class="header-shell">
        <div class="brand">
            <a href={withLocale('/', locale)} class="brand-title">
                <span class="brand-name">洛屿柒秋</span>
                <span class="brand-roman">Luo Yu Qi Qiu</span>
            </a>
        </div>

        <nav class="nav nav-center">
            <HeaderLink href={withLocale('/', locale)}>
		<span class="nav-label">
			<span>{getNavText(navigationContent.labels.home).primary}</span>
            {
                getNavText(navigationContent.labels.home).secondary && (
                            <span class="nav-sub">{getNavText(navigationContent.labels.home).secondary}</span>
                )
            }
		</span>
            </HeaderLink>

            <HeaderLink href={withLocale('/projects', locale)}>
		<span class="nav-label">
			<span>{getNavText(navigationContent.labels.projects).primary}</span>
            {
                getNavText(navigationContent.labels.projects).secondary && (
                            <span class="nav-sub">{getNavText(navigationContent.labels.projects).secondary}</span>
                )
            }
		</span>
            </HeaderLink>

            <HeaderLink href={withLocale('/blog', locale)}>
		<span class="nav-label">
			<span>{getNavText(navigationContent.labels.blog).primary}</span>
            {
                getNavText(navigationContent.labels.blog).secondary && (
                            <span class="nav-sub">{getNavText(navigationContent.labels.blog).secondary}</span>
                )
            }
		</span>
            </HeaderLink>

            <HeaderLink href={withLocale('/about', locale)}>
		<span class="nav-label">
			<span>{getNavText(navigationContent.labels.about).primary}</span>
            {
                getNavText(navigationContent.labels.about).secondary && (
                            <span class="nav-sub">{getNavText(navigationContent.labels.about).secondary}</span>
                )
            }
		</span>
            </HeaderLink>

            <HeaderLink href={withLocale('/resume', locale)}>
		<span class="nav-label">
			<span>{getNavText(navigationContent.labels.resume).primary}</span>
            {
                getNavText(navigationContent.labels.resume).secondary && (
                            <span class="nav-sub">{getNavText(navigationContent.labels.resume).secondary}</span>
                )
            }
		</span>
            </HeaderLink>
        </nav>

        <details class="language-switcher">
            <summary>
                {
                    typeof localeLabel === 'string' ? (
                        localeLabel
                    ) : (
                            <span class="locale-summary">
					<span>{localeLabel.primary}</span>
					<span class="locale-summary-sub">{localeLabel.secondary}</span>
				</span>
                    )
                }
            </summary>
            <div class="language-menu">
                {
                    switcherItems.map((item) => (
                            <a
                                    href={withLocale(pathname, item.locale)}
                                    class:list={{active: item.locale === locale}}
                            >
                                {item.label}
                            </a>
                    ))
                }
            </div>
        </details>
    </div>
</header>

<style>
    .site-header {
        position: sticky;
        top: 0;
        z-index: 20;
        padding: 1rem 1.25rem 0;
        background: linear-gradient(
                180deg,
                rgba(241, 246, 252, 0.92) 0%,
                rgba(241, 246, 252, 0.82) 65%,
                rgba(241, 246, 252, 0) 100%
        );
        backdrop-filter: blur(10px);
    }

    .header-shell {
        max-width: 1120px;
        margin: 0 auto;
        padding: 1.15rem 1.4rem;
        display: grid;
        grid-template-columns: 260px 1fr auto;
        align-items: center;
        gap: 2rem;
        border: 1px solid rgba(164, 182, 204, 0.35);
        border-radius: 22px;
        background: rgba(255, 255, 255, 0.88);
        box-shadow: 0 14px 36px rgba(20, 43, 74, 0.08);
    }

    .brand {
        min-width: 220px;
    }

    .brand-title {
        display: inline-flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 0.18rem;
        text-decoration: none;
        color: rgb(var(--black));
    }

    .brand-name {
        font-family: "Noto Serif SC", "Source Han Serif SC", "Songti SC", "STSong", "SimSun", serif;
        font-size: 1.72rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        line-height: 1.02;
        color: rgb(var(--black));
    }

    .brand-roman {
        font-family: "EB Garamond", "Times New Roman", Georgia, serif;
        font-size: 0.9rem;
        font-weight: 600;
        letter-spacing: 0.22em;
        line-height: 1.1;
        color: rgb(var(--gray));
        text-transform: none;
    }

    .brand-tagline {
        margin: 0.45rem 0 0;
        display: flex;
        flex-direction: column;
        gap: 0.1rem;
        font-size: 0.88rem;
        color: rgb(var(--gray));
        line-height: 1.35;
    }

    .brand-sub {
        font-size: 0.78rem;
        letter-spacing: 0.04em;
        opacity: 0.72;
    }

    .nav {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 1.4rem;
        align-items: center;
    }

    .nav a {
        padding: 0.45rem 0.1rem;
        color: rgb(var(--gray-dark));
        font-weight: 600;
        text-decoration: none;
        border-bottom: 2px solid transparent;
    }

    .nav a:hover,
    .nav a.active {
        color: var(--accent);
        border-bottom-color: var(--accent);
    }

    .nav-label {
        display: inline-flex;
        flex-direction: column;
        align-items: flex-start;
        line-height: 1.1;
        gap: 0.18rem;
    }
    
    .nav-center {
        justify-self: center;
    }

    .nav-sub {
        font-size: 0.82rem;
        font-weight: 500;
        opacity: 0.72;
    }
    
    .language-switcher {
        position: relative;
        justify-self: end;
    }

    .language-switcher summary {
        list-style: none;
        cursor: pointer;
        padding: 0.72rem 0.95rem;
        border: 1px solid rgba(164, 182, 204, 0.5);
        border-radius: 14px;
        background: #fff;
        color: rgb(var(--gray-dark));
        font-weight: 700;
        white-space: nowrap;
    }

    .language-switcher summary::-webkit-details-marker {
        display: none;
    }

    .language-menu {
        position: absolute;
        right: 0;
        top: calc(100% + 0.6rem);
        min-width: 250px;
        padding: 0.55rem;
        display: grid;
        gap: 0.35rem;
        border: 1px solid rgba(164, 182, 204, 0.34);
        border-radius: 16px;
        background: rgba(255, 255, 255, 0.97);
        box-shadow: 0 18px 38px rgba(20, 43, 74, 0.12);
    }

    .language-menu a {
        padding: 0.72rem 0.9rem;
        border-radius: 10px;
        color: rgb(var(--gray-dark));
        text-decoration: none;
        font-weight: 600;
    }

    .language-menu a:hover,
    .language-menu a.active {
        background: rgba(232, 240, 251, 0.92);
        color: var(--accent-dark);
    }

    .locale-summary {
        display: inline-flex;
        flex-direction: column;
        align-items: flex-start;
        line-height: 1.15;
        gap: 0.16rem;
    }

    .locale-summary-sub {
        font-size: 0.82rem;
        font-weight: 500;
        opacity: 0.72;
    }


    @media (max-width: 980px) {
        .header-shell {
            grid-template-columns: 1fr;
            align-items: flex-start;
        }

        .nav-center,
        .language-switcher {
            justify-self: start;
        }

        .nav {
            justify-content: flex-start;
        }
    }
</style>
